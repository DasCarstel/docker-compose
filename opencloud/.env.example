# OpenCloud Environment Variables
# Copy this file to .env and adjust values as needed

# Domain Configuration
OC_DOMAIN=opencloud.mueller-nas.de

# Admin Password (IMPORTANT: Set before first start!)
INITIAL_ADMIN_PASSWORD=admin1234

# Security
INSECURE=true

# OpenCloud Image (optional overrides)
# OC_DOCKER_IMAGE=opencloudeu/opencloud-rolling
# OC_DOCKER_TAG=latest

# Storage Paths (optional - defaults to docker volumes)
# OC_CONFIG_DIR=/etc/docker/opencloud/config
# OC_DATA_DIR=/mnt/opencloud-data

# Tika Search (already enabled in compose)
# SEARCH_EXTRACTOR_TYPE=tika
# SEARCH_EXTRACTOR_TIKA_TIKA_URL=http://tika:9998
# FRONTEND_FULL_TEXT_SEARCH_ENABLED=true

# Logging (optional)
# LOG_LEVEL=info
# LOG_PRETTY=false

# Default Language
# DEFAULT_LANGUAGE=de
