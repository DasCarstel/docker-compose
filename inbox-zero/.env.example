# =============================================================================
# Inbox Zero - .env.example
# Placeholder file for documentation. Copy to .env and fill in values.
# =============================================================================

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=inboxzero

# --- Domain ---
NEXT_PUBLIC_BASE_URL=https://inbox-zero.mueller-nas.de

# --- Redis / Queue ---
UPSTASH_REDIS_TOKEN=change-me

# --- Authentication Secrets ---
AUTH_SECRET=change-me
EMAIL_ENCRYPT_SECRET=change-me
EMAIL_ENCRYPT_SALT=change-me
INTERNAL_API_KEY=change-me
API_KEY_SALT=change-me
CRON_SECRET=change-me

# --- Google OAuth (REQUIRED) ---
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me

# --- Google PubSub (optional) ---
# GOOGLE_PUBSUB_TOPIC_NAME=projects/abc/topics/xyz
# GOOGLE_PUBSUB_VERIFICATION_TOKEN=change-me

# --- Microsoft OAuth (optional) ---
# MICROSOFT_CLIENT_ID=change-me
# MICROSOFT_CLIENT_SECRET=change-me
# MICROSOFT_WEBHOOK_CLIENT_STATE=change-me
# MICROSOFT_TENANT_ID=common

# --- LLM Provider: Google Gemini ---
DEFAULT_LLM_PROVIDER=google
DEFAULT_LLM_MODEL=gemini-2.0-flash-lite
ECONOMY_LLM_PROVIDER=google
ECONOMY_LLM_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=change-me

# --- Transactional Emails ---
RESEND_API_KEY=change-me

# --- Self-Hosted Settings ---
NEXT_PUBLIC_BYPASS_PREMIUM_CHECKS=true
# AUTO_JOIN_ORGANIZATION_ENABLED=true

# --- Optional: Feature Flags ---
# NEXT_PUBLIC_DIGEST_ENABLED=true
# NEXT_PUBLIC_MEETING_BRIEFS_ENABLED=true
# NEXT_PUBLIC_FOLLOW_UP_REMINDERS_ENABLED=true
