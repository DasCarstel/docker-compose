# authentik image version
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2026.5.3

# Critical — master secret for all crypto operations (REQUIRED, never change after setup)
AUTHENTIK_SECRET_KEY=<generate-a-secure-random-key>

# Cookie domain for SSO across subdomains (REQUIRED)
AUTHENTIK_COOKIE_DOMAIN=<your-domain.tld>

# PostgreSQL
PG_USER=authentik
PG_PASS=<generate-a-secure-password>
PG_DB=authentik

# --- Bootstrap — nur beim ERSTEN Start zum Erstellen des Admin-Accounts ---
# Können nach erfolgreicher Initialisierung auskommentiert/entfernt werden.
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=<generate-a-secure-password>
AUTHENTIK_BOOTSTRAP_TOKEN=changeme-initial-setup

# --- Optional — Token for internal authentik service communication ---
# Wird von authentik intern für die Kommunikation zwischen den Services verwendet.
AUTHENTIK_TOKEN=<generate-a-secure-token>
